#!/bin/bash
# Arnés de tests para los hooks del plugin.
# Uso: bash bin/dev/test-hooks.sh
#
# Patrón: cada caso corre en un tmpdir aislado, simula el estado de entrada,
# ejecuta el hook, y verifica exit code + salida. Adaptá los casos a los hooks
# reales de tu plugin.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GIT_HOOKS_DIR="$SCRIPT_DIR/git-hooks"
PASS=0
FAIL=0

_pass() { echo "  PASS: $1"; PASS=$((PASS + 1)); }
_fail() { echo "  FAIL: $1"; FAIL=$((FAIL + 1)); }

run_in_tmpdir() {
    local dir
    dir=$(mktemp -d)
    (cd "$dir" && eval "$1")
    local rc=$?
    rm -rf "$dir"
    return $rc
}

echo ""
echo "=== ejemplo: hook que falla en estado X ==="

# Caso de ejemplo — reemplazar por los hooks reales del plugin
result=$(run_in_tmpdir '
    out=$(echo "estado" | true 2>&1); rc=$?
    [ $rc -eq 0 ] && echo OK || echo "rc=$rc out=$out"
')
[ "$result" = "OK" ] && _pass "caso de ejemplo" || _fail "caso de ejemplo → $result"

echo ""
echo "Resultado: $PASS passed, $FAIL failed"
[ $FAIL -eq 0 ] && exit 0 || exit 1
