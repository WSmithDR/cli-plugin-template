#!/bin/bash
# post-commit: auto-bump version en TODOS los manifiestos y amenda el commit.
#
# Corre después del commit → lee el mensaje, calcula el bump → delega a
# bump-version.py (que toca plugin.json, marketplace.json, cli-config.yaml,
# opencode.json, gemini-extension.json, codex/cursor/copilot) → amenda.
#
# feat:              → minor
# fix|chore|docs|... → patch
# BREAKING (en msg)  → major

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PLUGIN_JSON="$REPO_ROOT/.claude-plugin/plugin.json"
# El sentinel vive en el git-dir REAL. En un worktree, $REPO_ROOT/.git es un
# ARCHIVO (apunta a .../.git/worktrees/<name>), no un directorio, así que
# touchear adentro falla con `set -e` y el bump nunca amenda. `git rev-parse
# --git-dir` resuelve la ruta correcta en repo normal y en worktree.
GIT_DIR="$(git rev-parse --git-dir)"
SENTINEL="$GIT_DIR/.version-bump-in-progress"

# Recursion guard: el `git commit --amend` de más abajo re-dispara post-commit
if [ -f "$SENTINEL" ]; then
    rm -f "$SENTINEL"
    exit 0
fi

[ ! -f "$PLUGIN_JSON" ] && exit 0

# Bump manual: plugin.json ya está en este commit → no tocar
if git show --name-only --format="" HEAD | grep -qx "\.claude-plugin/plugin\.json"; then
    exit 0
fi

MSG=$(git log -1 --pretty=%B)

# Determinar tipo de bump
if echo "$MSG" | grep -qiE "(BREAKING[ -]CHANGE|^.+!:)"; then
    BUMP="major"
elif echo "$MSG" | grep -qiE "^feat(\(.+\))?:"; then
    BUMP="minor"
else
    BUMP="patch"
fi

# Leer versión actual
CURRENT=$(python3 -c "
import json, os, re
v = json.load(open('$PLUGIN_JSON'))['version']
if not re.fullmatch(r'\d+\.\d+\.\d+', v):
    exit('version inválida: ' + v)
print(v)
")

# Delegar a bump-version.py — toca TODOS los manifiestos + cli-config.yaml
python3 "$REPO_ROOT/bin/bump-version.py" "$BUMP"

# Stagiar todo lo que bump-version.py tocó
# Comenzar con plugin.json + marketplace.json + cli-config.yaml (lo mínimo conocido)
# y agregar cualquier archivo adicional que cambiara
git add "$PLUGIN_JSON" 2>/dev/null || true
python3 -c "
import json, os
p = '$PLUGIN_JSON'
if os.path.exists(p):
    mkt = os.path.join(os.path.dirname(p), 'marketplace.json')
    if os.path.exists(mkt):
        print(mkt)
" | while read -r f; do git add "$f"; done
git add "$REPO_ROOT/cli-config.yaml" 2>/dev/null || true

# Detectar otros manifiestos que bump-version.py pudo haber cambiado
for f in opencode.json gemini-extension.json .codex-plugin/plugin.json \
         .cursor-plugin/plugin.json .copilot-plugin/plugin.json package.json; do
    [ -f "$REPO_ROOT/$f" ] && git add "$REPO_ROOT/$f"
done

touch "$SENTINEL"
git commit --amend --no-edit --no-verify
rm -f "$SENTINEL"
echo "  version: $CURRENT → $(python3 -c "import json; print(json.load(open('$PLUGIN_JSON'))['version'])") ($BUMP)"
