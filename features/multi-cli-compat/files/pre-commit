#!/bin/bash
# pre-commit: exige documentar cambios de compatibilidad multi-CLI.
#
# Si tocaste configs, manifests o scripts de compat multi-CLI pero NO
# actualizaste la documentación, el commit se rechaza a menos que el
# mensaje incluya "[skip-docs]" (escape explícito para cambios triviales).
#
# Instalar:
#   cp features/multi-cli-compat/files/pre-commit .githooks/pre-commit
#   chmod +x .githooks/pre-commit
#   git config core.hooksPath .githooks

set -euo pipefail

# Archivos que indican "toqué compatibilidad multi-CLI"
SENSITIVE=(
  'cli-config.yaml'
  '.claude-plugin/'
  '.codex-plugin/'
  '.cursor-plugin/'
  '.copilot-plugin/'
  'opencode.json'
  'gemini-extension.json'
  'features/multi-cli-compat/'
  'files/tool-mapping.md'
)

# Archivos que cuentan como documentación
DOCS=(
  'README.md'
  'AGENTS.md'
  'CLAUDE.md'
  'GEMINI.md'
  'CHANGELOG.md'
  'docs/'
)

staged=$(git diff --cached --name-only)
[ -z "$staged" ] && exit 0

# Escape explícito
MSG=$(git log -1 --pretty=%B 2>/dev/null || echo "")
if echo "$MSG" | grep -qi "\[skip-docs\]"; then
    exit 0
fi

touched_sensitive=false
touched_docs=false

for f in $staged; do
    for pattern in "${SENSITIVE[@]}"; do
        if [[ "$f" == $pattern ]]; then
            touched_sensitive=true
            break
        fi
    done
    for pattern in "${DOCS[@]}"; do
        if [[ "$f" == $pattern ]]; then
            touched_docs=true
            break
        fi
    done
done

if $touched_sensitive && ! $touched_docs; then
    cat <<'EOF'

✗ Cambiaste archivos de configuración multi-CLI pero no actualizaste la
  documentación. Si esto es nuevo aprendizaje sobre compatibilidad entre
  CLIs (hooks, schemas, tool-mapping, limitaciones), documentalo en
  README.md o docs/ antes de committear.

  Si el cambio es trivial y no merece docs, incluí [skip-docs] en el
  mensaje del commit para saltar esta verificación.

  git commit -m "fix: typo en config [skip-docs]"

EOF
    exit 1
fi

exit 0
