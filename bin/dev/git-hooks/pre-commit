#!/bin/bash
# Pre-commit del catálogo cli-plugin-template.
# Instalado via: bash bin/dev/setup.sh
#
# Corre, en orden, y cancela el commit si algo falla:
#   1. validate-catalog.py  — coherencia features/ ↔ CATALOG.md ↔ meta.yml + sync de versión
#   2. validate-evals.py    — schema de los evals de skills
#   3. tests                — hook SessionStart, gap de catálogo, evals
#   4. audit de portabilidad — bloquea solo ante hallazgos CRITICAL (--quiet)
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

fail() { echo ""; echo "✗ $1 — commit cancelado."; exit 1; }

echo "→ Validando catálogo..."
python3 bin/validate-catalog.py            || fail "catálogo inválido"

echo "→ Validando evals..."
python3 bin/validate-evals.py              || fail "evals inválidos"

echo "→ Corriendo tests..."
bash bin/test-hooks.sh                      || fail "tests de hooks fallaron"
bash bin/test-catalog-gaps.sh              || fail "tests de gap de catálogo fallaron"
bash bin/test-evals.sh                      || fail "tests de evals fallaron"
bash bin/test-bump-version.sh              || fail "tests de bump-version fallaron"
bash bin/test-post-commit.sh               || fail "tests de post-commit fallaron"

echo "→ Auditando portabilidad..."
python3 features/portability-audit/files/audit-portability.py . --quiet \
    || fail "hay hallazgos CRITICAL de portabilidad (rutas absolutas o secretos)"

# Exigir docs si se tocaron archivos multi-CLI
SENSITIVE=(
    'cli-config.yaml'
    '.claude-plugin/'
    '.codex-plugin/'
    '.cursor-plugin/'
    '.copilot-plugin/'
    'opencode.json'
    'gemini-extension.json'
    'features/multi-cli-compat/'
)
DOCS=('README.md' 'AGENTS.md' 'CLAUDE.md' 'GEMINI.md' 'CHANGELOG.md' 'docs/')
STAGED=$(git diff --cached --name-only)
MSG=$(git log -1 --pretty=%B 2>/dev/null || echo "")
if [ -n "$STAGED" ] && ! echo "$MSG" | grep -qi "\[skip-docs\]"; then
    ts=false; td=false
    for f in $STAGED; do
        for p in "${SENSITIVE[@]}"; do [[ "$f" == $p ]] && ts=true; done
        for p in "${DOCS[@]}"; do [[ "$f" == $p ]] && td=true; done
    done
    if $ts && ! $td; then
        echo ""
        echo "✗ Cambiaste archivos multi-CLI pero no docs."
        echo "  Incluí [skip-docs] en el mensaje si es trivial."
        echo ""
        exit 1
    fi
fi

echo "✓ Pre-commit OK"
